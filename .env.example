# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=controle_estoque
POSTGRES_USER=inv_user
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD

# ── FastAPI / JWT ─────────────────────────────────────────────────────────────
SECRET_KEY=CHANGE_ME_SECRET_KEY_256BIT_HEX
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── ESP32 API Key (header X-API-Key nos terminais físicos) ───────────────────
ESP32_API_KEY=CHANGE_ME_ESP32_API_KEY

# ── Domínio e TLS (produção VPS) ─────────────────────────────────────────────
DOMAIN=estoque.suaempresa.com
CERTBOT_EMAIL=admin@suaempresa.com
CERTBOT_STAGING=false        # true = usa Let's Encrypt staging (testes, sem rate limit)

# ── Segurança ─────────────────────────────────────────────────────────────────
SECURE_COOKIES=true          # false apenas em desenvolvimento HTTP local
ENVIRONMENT=production       # development | production

# ── Nginx (desenvolvimento local) ────────────────────────────────────────────
# Em produção as portas 80/443 são fixas; esta variável só é usada pelo override de dev
NGINX_PORT=8080
