# PostgreSQL
POSTGRES_DB=controle_estoque
POSTGRES_USER=sorv_user
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD

# FastAPI
SECRET_KEY=CHANGE_ME_SECRET_KEY_256BIT_HEX
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ESP32 API Key (static key enviado no header X-API-Key)
ESP32_API_KEY=CHANGE_ME_ESP32_API_KEY

# Nginx
NGINX_PORT=80

# Ambiente (development | production)
ENVIRONMENT=production
